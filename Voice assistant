const assistant = new (window.SpeechRecognition || window.webkitSpeechRecognition)();

assistant.lang = "en-US";
assistant.continuous = false;

let db = {};

fetch("http://localhost:3000/get-user")
.then(res => res.json())
.then(data => {
    db = data || {};
});

function startVoice(){
assistant.start();
document.getElementById("voice-status").innerText = "Listening...";
}

assistant.onresult = function(e){
let command = e.results[0][0].transcript.toLowerCase().trim();
document.getElementById("voice-status").innerText = command;
processCommand(command);
};

assistant.onend = function(){
document.getElementById("voice-status").innerText = "Voice Assistant Ready";
};

function speak(text){
window.speechSynthesis.speak(new SpeechSynthesisUtterance(text));
}

function processCommand(command){

if(command.includes("play")){
let song = command.replace("play","").trim();
if(song){
speak("Playing " + song);
window.open(
"https://www.youtube.com/results?search_query="+encodeURIComponent(song),
"_blank"
);
}
}

else if(command.includes("disease") || command.includes("symptom")){
speak("Opening disease checker");
window.location.href = "disease.html";
}

else if(command.includes("sos") || command.includes("help")){
speak("Emergency activated");
if(db.g1 && db.g1.p){
window.location.href = "tel:" + db.g1.p;
}
}

else if(command.includes("home") || command.includes("dashboard")){
speak("Going to dashboard");
window.location.href = "update2.html";
}

else if(command.includes("alarm") || command.includes("medicine")){
speak("Opening medicine section");
window.location.href = "alarm.html";
}

else{
speak("Sorry, command not recognized");
}

}
